<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Análisis de Punto de Equilibrio</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px; min-height: 100vh; }
        .container { max-width: 1200px; margin: 0 auto; background: white; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.3); padding: 30px; }
        h1 { text-align: center; color: #333; margin-bottom: 10px; font-size: 28px; }
        .subtitle { text-align: center; color: #666; margin-bottom: 30px; font-size: 14px; }
        .chart-container { position: relative; height: 400px; margin-bottom: 30px; background: #f9f9f9; border-radius: 8px; padding: 15px; }
        .metrics { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-top: 30px; }
        .metric-card { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); color: white; padding: 20px; border-radius: 8px; text-align: center; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3); }
        .metric-card.ganancia { background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); box-shadow: 0 4px 15px rgba(17, 153, 142, 0.3); }
        .metric-card.perdida { background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%); box-shadow: 0 4px 15px rgba(235, 51, 73, 0.3); }
        .metric-label { font-size: 12px; opacity: 0.9; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 10px; }
        .metric-value { font-size: 24px; font-weight: bold; }
        table { width: 100%; border-collapse: collapse; font-size: 14px; margin-top: 30px; }
        th { background: #667eea; color: white; padding: 12px; text-align: left; font-weight: 600; }
        td { padding: 12px; border-bottom: 1px solid #eee; }
        tr:hover { background: #f5f5f5; }
        .positivo { color: #11998e; font-weight: 600; }
        .negativo { color: #eb3349; font-weight: 600; }
    </style>
</head>
<body>
    <div class="container">
        <h1>📊 Análisis de Punto de Equilibrio</h1>
        <p class="subtitle">Comparativa de Comisiones vs Gastos Fijos por Mes</p>
        
        <div class="chart-container">
            <canvas id="myChart"></canvas>
        </div>
        
        <div class="metrics" id="metricsContainer"></div>
        
        <table id="dataTable">
            <thead>
                <tr>
                    <th>Mes</th>
                    <th>Comisiones</th>
                    <th>Gastos Fijos</th>
                    <th>Resultado</th>
                    <th>Estado</th>
                </tr>
            </thead>
            <tbody id="tableBody"></tbody>
        </table>
    </div>

    <script>
        const datosEjemplo = [
            { mes: "Enero", comisiones: 15000, gastos_fijos: 7200 },
            { mes: "Febrero", comisiones: 16500, gastos_fijos: 7200 },
            { mes: "Marzo", comisiones: 14800, gastos_fijos: 7200 },
            { mes: "Abril", comisiones: 18200, gastos_fijos: 7200 },
            { mes: "Mayo", comisiones: 17038, gastos_fijos: 7200 }
        ];

        let datos = datosEjemplo;
        let chart = null;

        function formatearMoneda(valor) {
            return new Intl.NumberFormat('es-MX', { style: 'currency', currency: 'MXN' }).format(valor);
        }

        function generarGrafico() {
            const meses = datos.map(d => d.mes);
            const comisiones = datos.map(d => d.comisiones);
            const gastosFijos = datos.map(d => d.gastos_fijos);
            const resultados = datos.map(d => d.comisiones - d.gastos_fijos);

            const ctx = document.getElementById('myChart').getContext('2d');
            if (chart) chart.destroy();

            chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: meses,
                    datasets: [
                        {
                            label: 'Comisiones',
                            data: comisiones,
                            borderColor: '#667eea',
                            backgroundColor: 'rgba(102, 126, 234, 0.1)',
                            borderWidth: 3,
                            fill: false,
                            tension: 0.4,
                            pointRadius: 6,
                            pointBackgroundColor: '#667eea'
                        },
                        {
                            label: 'Punto de Equilibrio',
                            data: gastosFijos,
                            borderColor: '#eb3349',
                            backgroundColor: 'rgba(235, 51, 73, 0.1)',
                            borderWidth: 3,
                            borderDash: [5, 5],
                            fill: false,
                            tension: 0.4,
                            pointRadius: 6,
                            pointBackgroundColor: '#eb3349'
                        },
                        {
                            label: 'Ganancia/Pérdida',
                            data: resultados,
                            borderColor: '#11998e',
                            backgroundColor: resultados.map(val => val >= 0 ? 'rgba(17, 153, 142, 0.3)' : 'rgba(235, 51, 73, 0.3)'),
                            borderWidth: 2,
                            fill: true,
                            tension: 0.4,
                            pointRadius: 5
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: true, position: 'top' },
                        tooltip: {
                            backgroundColor: 'rgba(0,0,0,0.8)',
                            padding: 12,
                            callbacks: {
                                label: function(context) {
                                    return context.dataset.label + ': ' + formatearMoneda(context.parsed.y);
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: function(value) {
                                    return '$' + value.toLocaleString('es-MX');
                                }
                            }
                        }
                    }
                }
            });

            const container = document.getElementById('metricsContainer');
            container.innerHTML = '';
            const comisionesTotales = datos.reduce((sum, d) => sum + d.comisiones, 0);
            const gastosTotales = datos.reduce((sum, d) => sum + d.gastos_fijos, 0);
            const gananciaTotal = comisionesTotales - gastosTotales;

            [
                { label: 'Comisiones Totales', valor: formatearMoneda(comisionesTotales), clase: '' },
                { label: 'Gastos Fijos', valor: formatearMoneda(gastosTotales), clase: '' },
                { label: 'Ganancia Total', valor: formatearMoneda(gananciaTotal), clase: gananciaTotal >= 0 ? 'ganancia' : 'perdida' }
            ].forEach(metrica => {
                const card = document.createElement('div');
                card.className = `metric-card ${metrica.clase}`;
                card.innerHTML = `<div class="metric-label">${metrica.label}</div><div class="metric-value">${metrica.valor}</div>`;
                container.appendChild(card);
            });

            const tbody = document.getElementById('tableBody');
            tbody.innerHTML = '';
            datos.forEach(d => {
                const resultado = d.comisiones - d.gastos_fijos;
                const estado = resultado >= 0 ? 'GANANCIA ✓' : 'PÉRDIDA ✗';
                const clase = resultado >= 0 ? 'positivo' : 'negativo';
                const row = document.createElement('tr');
                row.innerHTML = `<td><strong>${d.mes}</strong></td><td>${formatearMoneda(d.comisiones)}</td><td>${formatearMoneda(d.gastos_fijos)}</td><td class="${clase}">${formatearMoneda(resultado)}</td><td class="${clase}"><strong>${estado}</strong></td>`;
                tbody.appendChild(row);
            });
        }

        document.addEventListener('DOMContentLoaded', function() {
            generarGrafico();
        });
    </script>
</body>
</html>
